{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sami-gsd.local/schemas/benchmark_validation_report_v4.schema.json",
  "title": "SAMI Benchmark Validation Report v4",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "errors",
    "warnings",
    "benchmark_manifest_sha256",
    "artifact_count",
    "materialized_asset_count",
    "materialized_size_bytes",
    "source_record_count",
    "parent_count",
    "split_counts",
    "assurance_counts",
    "eligibility_counts",
    "normalization_binding_sha256",
    "aggregate_sha256",
    "schema_version",
    "protocol"
  ],
  "properties": {
    "errors": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "warnings": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "benchmark_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "artifact_count": {"$ref": "#/$defs/count"},
    "materialized_asset_count": {"$ref": "#/$defs/count"},
    "materialized_size_bytes": {"$ref": "#/$defs/count"},
    "source_record_count": {"$ref": "#/$defs/count"},
    "parent_count": {"$ref": "#/$defs/count"},
    "split_counts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "train": {"$ref": "#/$defs/count"},
        "val": {"$ref": "#/$defs/count"},
        "test": {"$ref": "#/$defs/count"}
      }
    },
    "assurance_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_group_isolated",
        "source_declared_unverified",
        "train_only"
      ],
      "properties": {
        "verified_group_isolated": {"const": 0},
        "source_declared_unverified": {"$ref": "#/$defs/count"},
        "train_only": {"$ref": "#/$defs/count"}
      }
    },
    "eligibility_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strict", "exploratory", "train_only"],
      "properties": {
        "strict": {"const": 0},
        "exploratory": {"$ref": "#/$defs/count"},
        "train_only": {"$ref": "#/$defs/count"}
      }
    },
    "normalization_binding_sha256": {"$ref": "#/$defs/sha256"},
    "aggregate_sha256": {"$ref": "#/$defs/sha256"},
    "schema_version": {"const": "sami_benchmark_validation_report_v4"},
    "protocol": {"const": "sami_hdf5_materialized_copy_validator_v1"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "count": {"type": "integer", "minimum": 0}
  }
}
