{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sami-gsd.local/schemas/hdf5_source_record_v1.schema.json",
  "title": "SAMI HDF5 Source Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_key",
    "source_sample_id",
    "ingestion_status",
    "source_declared_split",
    "canonical_split",
    "split_assurance",
    "evaluation_eligibility",
    "group",
    "duplicate_component",
    "image",
    "mask",
    "channels",
    "validity",
    "provenance",
    "record_sha256",
    "schema_version"
  ],
  "properties": {
    "source_key": {"type": "string", "minLength": 1},
    "source_sample_id": {"type": "string", "minLength": 1},
    "ingestion_status": {"const": "ready"},
    "source_declared_split": {
      "type": ["string", "null"],
      "enum": ["train", "val", "test", null]
    },
    "canonical_split": {"enum": ["train", "val", "test"]},
    "split_assurance": {
      "enum": [
        "verified_group_isolated",
        "source_declared_unverified",
        "train_only"
      ]
    },
    "evaluation_eligibility": {
      "enum": ["strict", "exploratory", "train_only"]
    },
    "group": {"$ref": "#/$defs/group"},
    "duplicate_component": {"$ref": "#/$defs/duplicate_component"},
    "image": {"$ref": "#/$defs/image_ref"},
    "mask": {"$ref": "#/$defs/mask_ref"},
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/channel"}
    },
    "validity": {"$ref": "#/$defs/validity"},
    "provenance": {"$ref": "#/$defs/provenance"},
    "record_sha256": {"$ref": "#/$defs/sha256"},
    "schema_version": {"const": "sami_hdf5_source_record_v1"}
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "split_assurance": {"const": "verified_group_isolated"}
        }
      },
      "then": {
        "properties": {"evaluation_eligibility": {"const": "strict"}}
      }
    },
    {
      "if": {
        "properties": {
          "split_assurance": {"const": "source_declared_unverified"}
        }
      },
      "then": {
        "properties": {"evaluation_eligibility": {"const": "exploratory"}}
      }
    },
    {
      "if": {"properties": {"split_assurance": {"const": "train_only"}}},
      "then": {
        "properties": {
          "canonical_split": {"const": "train"},
          "evaluation_eligibility": {"const": "train_only"}
        }
      }
    },
    {
      "if": {"properties": {"source_declared_split": {"const": "train"}}},
      "then": {"properties": {"canonical_split": {"const": "train"}}}
    },
    {
      "if": {"properties": {"source_declared_split": {"const": "val"}}},
      "then": {"properties": {"canonical_split": {"const": "val"}}}
    },
    {
      "if": {"properties": {"source_declared_split": {"const": "test"}}},
      "then": {"properties": {"canonical_split": {"const": "test"}}}
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "source_dataset_path": {
      "type": "string",
      "pattern": "^datasets/(?!.*(?:^|/)\\.\\.?/).+\\.(?:h5|hdf5)$"
    },
    "benchmark_dataset_path": {
      "type": "string",
      "pattern": "^benchmark/sami_landslide_hdf5_v4/small/assets/(?!.*(?:^|/)\\.\\.?/).+\\.(?:h5|hdf5)$"
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["group_id", "group_kind", "evidence", "completeness"],
      "properties": {
        "group_id": {"type": ["string", "null"], "minLength": 1},
        "group_kind": {
          "enum": ["scene", "event", "location", "source_sample", "unknown"]
        },
        "evidence": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "completeness": {"enum": ["verified", "partial", "unavailable"]}
      },
      "allOf": [
        {
          "if": {"properties": {"completeness": {"const": "verified"}}},
          "then": {"properties": {"group_id": {"type": "string"}}}
        }
      ]
    },
    "duplicate_component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component_id", "evidence_level"],
      "properties": {
        "component_id": {"type": ["string", "null"], "minLength": 1},
        "evidence_level": {"enum": ["verified", "candidate", "unavailable"]}
      },
      "allOf": [
        {
          "if": {"properties": {"evidence_level": {"const": "verified"}}},
          "then": {"properties": {"component_id": {"type": "string"}}}
        },
        {
          "if": {"properties": {"evidence_level": {"const": "unavailable"}}},
          "then": {"properties": {"component_id": {"type": "null"}}}
        }
      ]
    },
    "image_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_logical_path",
        "benchmark_logical_path",
        "sha256",
        "size_bytes",
        "dataset_key",
        "shape",
        "dtype",
        "layout",
        "value_semantics"
      ],
      "properties": {
        "source_logical_path": {"$ref": "#/$defs/source_dataset_path"},
        "benchmark_logical_path": {"$ref": "#/$defs/benchmark_dataset_path"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "size_bytes": {"type": "integer", "minimum": 1},
        "dataset_key": {"const": "/image"},
        "shape": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {"type": "integer", "minimum": 1}
        },
        "dtype": {"const": "float32"},
        "layout": {"const": "CHW"},
        "value_semantics": {"type": "null"}
      }
    },
    "mask_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_logical_path",
        "benchmark_logical_path",
        "sha256",
        "size_bytes",
        "dataset_key",
        "shape",
        "dtype",
        "layout",
        "value_semantics"
      ],
      "properties": {
        "source_logical_path": {"$ref": "#/$defs/source_dataset_path"},
        "benchmark_logical_path": {"$ref": "#/$defs/benchmark_dataset_path"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "size_bytes": {"type": "integer", "minimum": 1},
        "dataset_key": {"const": "/mask"},
        "shape": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {"type": "integer", "minimum": 1}
        },
        "dtype": {"const": "uint8"},
        "layout": {"const": "HW"},
        "value_semantics": {
          "const": {"0": "background", "1": "landslide"}
        }
      }
    },
    "channel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "index",
        "channel_key",
        "display_name",
        "modality_family",
        "physical_unit",
        "wavelength_nm",
        "wavelength_known",
        "gsd_m",
        "gsd_known",
        "normalization",
        "validity_source",
        "schema_version"
      ],
      "properties": {
        "index": {"type": "integer", "minimum": 0},
        "channel_key": {"type": "string", "minLength": 1},
        "display_name": {"type": "string", "minLength": 1},
        "modality_family": {
          "enum": [
            "optical",
            "multispectral",
            "dem",
            "slope",
            "sar",
            "insar",
            "other"
          ]
        },
        "physical_unit": {"type": ["string", "null"], "minLength": 1},
        "wavelength_nm": {
          "type": ["number", "null"],
          "exclusiveMinimum": 0
        },
        "wavelength_known": {"type": "boolean"},
        "gsd_m": {"type": ["number", "null"], "exclusiveMinimum": 0},
        "gsd_known": {"type": "boolean"},
        "normalization": {
          "enum": [
            "none",
            "divide_255",
            "zscore_valid_pixels",
            "source_preprocessed"
          ]
        },
        "validity_source": {
          "enum": [
            "channel_valid",
            "pixel_valid",
            "valid_mask",
            "implicit_present"
          ]
        },
        "schema_version": {"const": "sami_channel_descriptor_v1"}
      },
      "allOf": [
        {
          "if": {"properties": {"wavelength_known": {"const": false}}},
          "then": {"properties": {"wavelength_nm": {"type": "null"}}},
          "else": {"properties": {"wavelength_nm": {"type": "number"}}}
        },
        {
          "if": {"properties": {"gsd_known": {"const": false}}},
          "then": {"properties": {"gsd_m": {"type": "null"}}},
          "else": {"properties": {"gsd_m": {"type": "number"}}}
        },
        {
          "if": {
            "properties": {
              "modality_family": {
                "enum": ["dem", "slope", "sar", "insar"]
              }
            }
          },
          "then": {
            "properties": {
              "wavelength_known": {"const": false},
              "wavelength_nm": {"type": "null"}
            }
          }
        }
      ]
    },
    "validity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "valid_mask_key",
        "valid_mask_owner",
        "pixel_valid_key",
        "pixel_valid_owner",
        "channel_valid_key",
        "channel_valid_owner",
        "label_valid_semantics",
        "input_pixel_valid_derivation",
        "notes"
      ],
      "properties": {
        "valid_mask_key": {
          "type": ["string", "null"],
          "pattern": "^/[^/].*"
        },
        "valid_mask_owner": {
          "enum": ["image_hdf5", "mask_hdf5", "absent"]
        },
        "pixel_valid_key": {
          "type": ["string", "null"],
          "pattern": "^/[^/].*"
        },
        "pixel_valid_owner": {
          "enum": ["image_hdf5", "mask_hdf5", "absent"]
        },
        "channel_valid_key": {
          "type": ["string", "null"],
          "pattern": "^/[^/].*"
        },
        "channel_valid_owner": {
          "enum": ["image_hdf5", "mask_hdf5", "absent"]
        },
        "label_valid_semantics": {"type": "string", "minLength": 1},
        "input_pixel_valid_derivation": {
          "enum": [
            "read_per_channel_pixel_valid",
            "broadcast_label_valid_to_present_channels",
            "broadcast_present_channels_over_full_grid"
          ]
        },
        "notes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      },
      "allOf": [
        {
          "if": {"properties": {"valid_mask_owner": {"const": "absent"}}},
          "then": {"properties": {"valid_mask_key": {"type": "null"}}},
          "else": {"properties": {"valid_mask_key": {"type": "string"}}}
        },
        {
          "if": {"properties": {"pixel_valid_owner": {"const": "absent"}}},
          "then": {"properties": {"pixel_valid_key": {"type": "null"}}},
          "else": {"properties": {"pixel_valid_key": {"type": "string"}}}
        },
        {
          "if": {"properties": {"channel_valid_owner": {"const": "absent"}}},
          "then": {"properties": {"channel_valid_key": {"type": "null"}}},
          "else": {"properties": {"channel_valid_key": {"type": "string"}}}
        },
        {
          "if": {
            "properties": {
              "input_pixel_valid_derivation": {
                "const": "read_per_channel_pixel_valid"
              }
            }
          },
          "then": {"properties": {"pixel_valid_key": {"type": "string"}}}
        },
        {
          "if": {
            "properties": {
              "input_pixel_valid_derivation": {
                "const": "broadcast_label_valid_to_present_channels"
              }
            }
          },
          "then": {"properties": {"valid_mask_key": {"type": "string"}}}
        }
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_name",
        "source_document",
        "citation_key",
        "upstream_url",
        "provenance_notes"
      ],
      "properties": {
        "source_name": {"type": "string", "minLength": 1},
        "source_document": {
          "type": ["string", "null"],
          "pattern": "^datasets/"
        },
        "citation_key": {"type": "string", "minLength": 1},
        "upstream_url": {
          "type": ["string", "null"],
          "pattern": "^https://"
        },
        "provenance_notes": {"type": "string", "minLength": 1}
      }
    }
  }
}
