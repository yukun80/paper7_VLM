{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sami-gsd.local/schemas/materialized_hdf5_asset_v1.schema.json",
  "title": "SAMI Materialized HDF5 Asset v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "role",
    "source_key",
    "source_logical_path",
    "benchmark_logical_path",
    "sha256",
    "size_bytes"
  ],
  "properties": {
    "schema_version": {"const": "sami_materialized_hdf5_asset_v1"},
    "role": {"enum": ["image", "mask"]},
    "source_key": {"type": "string", "minLength": 1},
    "source_logical_path": {
      "type": "string",
      "pattern": "^datasets/(?!.*(?:^|/)\\.\\.?/).+\\.(?:h5|hdf5)$"
    },
    "benchmark_logical_path": {
      "type": "string",
      "pattern": "^benchmark/sami_landslide_hdf5_v4/small/assets/(?!.*(?:^|/)\\.\\.?/).+\\.(?:h5|hdf5)$"
    },
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "size_bytes": {"type": "integer", "minimum": 1}
  }
}
