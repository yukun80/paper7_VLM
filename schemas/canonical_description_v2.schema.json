{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sami-groundsegdesc.local/schemas/canonical_description_v2.schema.json",
  "title": "SAMI Canonical Description v2 Component-License-Bound",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "parent_id",
    "source_key",
    "component",
    "component_license_key",
    "component_license_sha256",
    "role",
    "split_policy",
    "split",
    "image_ref",
    "valid_mask_ref",
    "source_image_sha256",
    "source_record_sha256",
    "answers",
    "region_box_half_open",
    "training_eligible"
  ],
  "properties": {
    "schema_version": {"const": "sami_canonical_description_v2_component_license_bound"},
    "record_id": {"type": "string", "minLength": 1},
    "parent_id": {"type": "string", "minLength": 1},
    "source_key": {"enum": ["mmrs_1m", "rsgpt"]},
    "component": {"enum": ["rsicd", "ucm", "sydney", "nwpu", "rsitmd", "dior_rsvg", "rsicap", "rsieval"]},
    "component_license_key": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*:[a-z0-9][a-z0-9_-]*$"
    },
    "component_license_sha256": {"$ref": "#/$defs/sha256"},
    "role": {"enum": ["global_caption", "region_short_phrase"]},
    "split_policy": {"enum": ["train_candidate", "permanent_test_only"]},
    "split": {"enum": ["train", "val", "test"]},
    "image_ref": {"$ref": "#/$defs/artifactRef"},
    "valid_mask_ref": {"$ref": "#/$defs/artifactRef"},
    "source_image_sha256": {"$ref": "#/$defs/sha256"},
    "source_record_sha256": {"$ref": "#/$defs/sha256"},
    "answers": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/answer"}
    },
    "region_box_half_open": {
      "oneOf": [{"type": "null"}, {"$ref": "#/$defs/halfOpenBox"}]
    },
    "training_eligible": {"type": "boolean"}
  },
  "allOf": [
    {
      "if": {"properties": {"component": {"const": "dior_rsvg"}}},
      "then": {
        "properties": {
          "role": {"const": "region_short_phrase"},
          "region_box_half_open": {"$ref": "#/$defs/halfOpenBox"}
        }
      },
      "else": {
        "properties": {
          "role": {"const": "global_caption"},
          "region_box_half_open": {"type": "null"}
        }
      }
    },
    {
      "if": {"properties": {"split_policy": {"const": "permanent_test_only"}}},
      "then": {
        "properties": {
          "split": {"const": "test"},
          "training_eligible": {"const": false}
        }
      }
    }
  ],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)(?!.*\\\\).+$"
    },
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"$ref": "#/$defs/portablePath"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "halfOpenBox": {
      "type": "array",
      "prefixItems": [
        {"type": "integer", "minimum": 0},
        {"type": "integer", "minimum": 0},
        {"type": "integer", "minimum": 1},
        {"type": "integer", "minimum": 1}
      ],
      "minItems": 4,
      "maxItems": 4
    },
    "answer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_answer_id", "text", "annotation_origin", "source_index_sha256"],
      "properties": {
        "source_answer_id": {"type": "string", "minLength": 1},
        "text": {"type": "string", "minLength": 1},
        "annotation_origin": {"enum": ["source_caption", "source_expression"]},
        "source_index_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
