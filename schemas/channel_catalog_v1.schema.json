{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sami-gsd.local/schemas/channel_catalog_v1.schema.json",
  "title": "SAMI Channel Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "protocol",
    "ordering_rule",
    "entries",
    "aggregate_sha256"
  ],
  "properties": {
    "schema_version": {"const": "sami_channel_catalog_v1"},
    "protocol": {"const": "explicit_channel_semantics_v1"},
    "ordering_rule": {
      "const": "channel_token_is_lexicographic_channel_key_not_tensor_order"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/channel_entry"}
    },
    "aggregate_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "channel_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "channel_token",
        "channel_key",
        "modality_family",
        "wavelength_nm",
        "wavelength_known",
        "gsd_m",
        "gsd_known",
        "source_bindings"
      ],
      "properties": {
        "channel_token": {"type": "integer", "minimum": 0},
        "channel_key": {"type": "string", "minLength": 1},
        "modality_family": {
          "enum": ["optical", "multispectral", "dem", "slope", "sar", "insar", "other"]
        },
        "wavelength_nm": {"type": ["number", "null"], "exclusiveMinimum": 0},
        "wavelength_known": {"type": "boolean"},
        "gsd_m": {"type": ["number", "null"], "exclusiveMinimum": 0},
        "gsd_known": {"type": "boolean"},
        "source_bindings": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/source_binding"}
        }
      }
    },
    "source_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_key",
        "source_index",
        "display_name",
        "physical_unit",
        "normalization",
        "validity_source",
        "descriptor_sha256"
      ],
      "properties": {
        "source_key": {"type": "string", "minLength": 1},
        "source_index": {"type": "integer", "minimum": 0},
        "display_name": {"type": "string", "minLength": 1},
        "physical_unit": {"type": ["string", "null"], "minLength": 1},
        "normalization": {
          "enum": ["none", "divide_255", "zscore_valid_pixels", "source_preprocessed"]
        },
        "validity_source": {
          "enum": ["channel_valid", "pixel_valid", "valid_mask", "implicit_present"]
        },
        "descriptor_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
