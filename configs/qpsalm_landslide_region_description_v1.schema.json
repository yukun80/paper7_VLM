{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "qpsalm_landslide_region_description_v1.schema.json",
  "title": "QPSALM Landslide Bridge region record",
  "type": "object",
  "required": [
    "schema_version", "bridge_record_id", "parent_sample_id", "source_benchmark",
    "split", "dataset_name", "region_id", "region_source", "target_status",
    "task_family", "instruction", "condition", "answer_type",
    "region_geometry", "region_mask", "visual_ref", "modality_evidence",
    "structured_targets", "candidate", "review", "provenance", "quality_flags"
  ],
  "properties": {
    "schema_version": {"const": "qpsalm_landslide_region_description_v1"},
    "bridge_record_id": {"type": "string", "minLength": 1},
    "parent_sample_id": {"type": "string", "minLength": 1},
    "source_benchmark": {"type": "string", "pattern": "^benchmark/"},
    "split": {"enum": ["train", "val", "test"]},
    "dataset_name": {"type": "string", "minLength": 1},
    "region_id": {"type": "string", "minLength": 1},
    "region_source": {"enum": ["gt_global_mask", "pseudo_instance_component", "gt_referring_mask", "no_target"]},
    "target_status": {"enum": ["present", "absent", "uncertain"]},
    "task_family": {"enum": ["landslide_region_caption", "no_target_response"]},
    "instruction": {"type": "string", "minLength": 1},
    "condition": {"type": "string", "minLength": 1},
    "answer_type": {"const": "structured_json_with_summary"},
    "region_geometry": {"type": "object"},
    "region_mask": {
      "type": ["object", "null"],
      "properties": {
        "path": {"type": "string", "pattern": "^benchmark/"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "shape": {"type": "array", "minItems": 2, "maxItems": 2}
      }
    },
    "visual_ref": {
      "type": "object",
      "required": ["type", "parent_index", "modality_paths"],
      "properties": {
        "type": {"const": "multisource_parent"},
        "parent_index": {"type": "string", "pattern": "^benchmark/"},
        "modality_paths": {"type": "object"}
      }
    },
    "modality_evidence": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["evidence_level", "coverage", "value_space", "observation"],
        "properties": {
          "evidence_level": {"enum": ["A_physical", "B_normalized_relative", "C_unavailable"]},
          "coverage": {"type": "number", "minimum": 0.0, "maximum": 1.0},
          "value_space": {"enum": ["physical", "normalized", "unavailable"]},
          "observation": {"type": "string"}
        }
      }
    },
    "structured_targets": {"type": "object"},
    "candidate": {
      "type": "object",
      "required": ["origin", "summary", "is_expert_truth"],
      "properties": {
        "origin": {"enum": ["deterministic_rules", "optional_teacher", "expert"]},
        "summary": {"type": "string"},
        "is_expert_truth": {"type": "boolean"}
      }
    },
    "review": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {"enum": ["not_selected", "pending", "accepted", "revised", "rejected", "needs_arbitration", "arbitrated"]}
      }
    },
    "provenance": {"type": "object"},
    "quality_flags": {"type": "array", "items": {"type": "string"}}
  }
}
