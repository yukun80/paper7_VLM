###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/地层岩石类型
:地层岩石类型 rdf:type owl:Class ;
        rdfs:subClassOf :地层岩土 ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :决定 ;
                          owl:someValuesFrom :地层土体类型
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :决定 ;
                          owl:someValuesFrom :地层岩土强度
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :决定 ;
                          owl:someValuesFrom :岩土颗粒组分
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :决定 ;
                          owl:someValuesFrom :斜坡类型
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :影响 ;
                          owl:someValuesFrom <http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8#含/隔水层>
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :影响 ;
                          owl:someValuesFrom :地表水入渗
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :影响 ;
                          owl:someValuesFrom :岩土矿物成分
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :影响 ;
                          owl:someValuesFrom :斜坡结构
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :影响 ;
                          owl:someValuesFrom :裂隙
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :影响 ;
                          owl:someValuesFrom <http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/含/含/含/水层透水性>
                        ] ;
        :说明 """地层岩石类型
	碎屑岩建造34.7%  极
		括砂岩、泥岩和砾岩等颗粒状岩石
	岩浆岩建造21.4%  高
		花岗岩，安山岩，玄武岩等岩浆制坚硬岩石
	变质岩建造21.7%  高
		片麻岩、云母片岩、似云母片岩、石英片岩、千枚岩、页岩和绿泥石岩等
	碳酸盐岩建造19%  中
		石灰岩，白云石岩，钙质岩，方解石岩等""" .


