#    Object Properties
#################################################################

###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/冲刷侵蚀1
:冲刷侵蚀1 rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf :语义关系 ;
       rdfs:domain :地下水 ,
                   :地表水 ;
       rdfs:range :地层岩土 ,
                  :地层岩土强度 ,
                  :斜坡结构 .


###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/决定
:决定 rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdf:type owl:TransitiveProperty .


###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/基本条件
:基本条件 rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf :语义关系 .


###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/影响
:影响 rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdf:type owl:TransitiveProperty ;
    rdfs:comment "底层概念之间确有相关关系，但无法确定对于滑坡发生这一本体事件属于正向或负向。" .


###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/必备参数
:必备参数 rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/构造
:构造 rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :语义关系 ;
    rdfs:domain :地表水 ;
    rdfs:range :节理 ,
               :裂隙 .


###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/次生灾害
:次生灾害 rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf :语义关系 .


###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/正向促进
:正向促进 rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf owl:topObjectProperty ;
      owl:inverseOf :负向降低 ;
      rdf:type owl:TransitiveProperty .


###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/滑坡内因
:滑坡内因 rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf owl:topObjectProperty ;
      rdf:type owl:InverseFunctionalProperty ,
               owl:AsymmetricProperty .


###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/滑坡诱因
:滑坡诱因 rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf owl:topObjectProperty ;
      rdf:type owl:TransitiveProperty .


###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/相互作用
:相互作用 rdf:type owl:ObjectProperty ,
               owl:TransitiveProperty .


###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/破坏
:破坏 rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf :语义关系 ;
    rdfs:domain :坡面侵蚀度 ;
    rdfs:range :斜坡结构 .


###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/语义关系
:语义关系 rdf:type owl:ObjectProperty ,
               owl:TransitiveProperty ;
      rdfs:comment "语义关系是底层概念之间的相互影响关系，数量众多，种类复杂。大多是属于在诱因之间的相互关系。" .


###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/负向降低
:负向降低 rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf owl:topObjectProperty ;
      rdf:type owl:TransitiveProperty .


###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/软化泥化1
:软化泥化1 rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf :语义关系 ;
       rdfs:domain <http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8#含/隔水层> ,
                   :地下水 ,
                   :地表水 ;
       rdfs:range :地层岩土 .


