                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :影响 ;
                         owl:someValuesFrom :地下水埋深
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :影响 ;
                         owl:someValuesFrom :地层岩土厚度
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :影响 ;
                         owl:someValuesFrom :地层岩土强度
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :影响 ;
                         owl:someValuesFrom :地表水入渗
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :影响 ;
                         owl:someValuesFrom :坡度
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :影响 ;
                         owl:someValuesFrom :坡形
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :影响 ;
                         owl:someValuesFrom :坡面侵蚀度
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :影响 ;
                         owl:someValuesFrom :斜坡类型
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :影响 ;
                         owl:someValuesFrom :斜坡结构
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :影响 ;
                         owl:someValuesFrom :水层分布
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :影响 ;
                         owl:someValuesFrom :节理
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :影响 ;
