###  http://www.semanticweb.org/94180/ontologies/2023/3/untitled-ontology-8/坡面侵蚀度
:坡面侵蚀度 rdf:type owl:Class ;
       rdfs:subClassOf :地层岩土 ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :决定 ;
                         owl:someValuesFrom :岩土颗粒组分
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :影响 ;
                         owl:someValuesFrom :斜坡结构
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :正向促进 ;
                         owl:someValuesFrom :临空区
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :正向促进 ;
                         owl:someValuesFrom :土层渗透性
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :正向促进 ;
                         owl:someValuesFrom :地层岩土厚度
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :正向促进 ;
                         owl:someValuesFrom :地层岩土强度
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :正向促进 ;
                         owl:someValuesFrom :地形海拔
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :正向促进 ;
                         owl:someValuesFrom :坡度
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :正向促进 ;
                         owl:someValuesFrom :易发区
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :正向促进 ;
                         owl:someValuesFrom :裂隙
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :负向降低 ;
                         owl:someValuesFrom :土层密实度
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :负向降低 ;
                         owl:someValuesFrom :地层岩土含水率
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :负向降低 ;
                         owl:someValuesFrom :地层岩土强度
                       ] .


