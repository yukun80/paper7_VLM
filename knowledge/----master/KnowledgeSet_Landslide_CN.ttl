                    [ rdf:type owl:Restriction ;
                      owl:onProperty :影响 ;
                      owl:someValuesFrom :地下水流量
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :影响 ;
                      owl:someValuesFrom :地层岩土含水率
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :影响 ;
                      owl:someValuesFrom :地层岩土强度
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :影响 ;
                      owl:someValuesFrom :地层岩石类型
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :影响 ;
                      owl:someValuesFrom :地表水入渗
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :影响 ;
                      owl:someValuesFrom :地表水冲刷
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :影响 ;
                      owl:someValuesFrom :地表水径流
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :影响 ;
                      owl:someValuesFrom :岩土颗粒组分
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :正向促进 ;
                      owl:someValuesFrom :土层渗透性
                    ] ,
