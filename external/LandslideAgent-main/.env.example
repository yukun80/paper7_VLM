# Service
HOST=0.0.0.0
PORT=8003
LLM_MOCK=1

# Python interpreters for separated model environments
LLM_ENV_PYTHON=python
SEG_ENV_PYTHON=python
CLS_ENV_PYTHON=python

# LLM model paths. Leave empty when using LLM_MOCK=1.
LLM_MODEL_PATH=
LLM_LORA_PATH=
LLM_DEFAULT_MAX_TOKENS=1024
LLM_MAX_TOKENS_CAP=4096

# OpenMMLab segmentation
SEG_BACKEND=mmseg
MMSEG_CONFIG_PATH=
MMSEG_CHECKPOINT_PATH=
MMSEG_DEVICE=cpu
MMSEG_LANDSLIDE_CLASS_INDEX=1
MMSEG_FOREGROUND_NONZERO=0

# MMPreTrain classification
MMPRETRAIN_ROOT=
CLS_CONFIG_PATH=
CLS_CHECKPOINT_PATH=
CLS_CLASS_MAPPING_PATH=
CLS_DEVICE=cpu

# Optional geo background service
OPENTOPOGRAPHY_API_KEY=
OPENTOPOGRAPHY_DEMTYPE=COP30
GEO_BACKGROUND_SLOPE_SAMPLE_METERS=30
